meta {
  name: Get Pet By Id
  type: http
  seq: 3
}

get {
  url: {{Host}}/api/pets/00000000-0000-0000-0000-000000000001
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

tests {
  test("returns pet with species id", function () {
    const body = res.getBody();
    const speciesId = body.speciesId ?? body.specieId;

    expect(res.getStatus()).to.equal(200);
    expect(body.id).to.not.equal(undefined);
    expect(speciesId).to.not.equal(undefined);
  });
}
